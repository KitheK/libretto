---
interface Props {
  title?: string;
  navCurrent?: 'guides' | 'system' | 'flows' | 'agents';
}

const { title, navCurrent = 'guides' } = Astro.props;

const capstoneRepo = 'https://github.com/UBCO-COSC499-S2026/capstone-team-1';
const librettoRepo = 'https://github.com/KitheK/libretto';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Libretto — the blueprint to our capstone Canvas assistant" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title ? `${title} · Libretto` : 'Libretto'}</title>
  </head>
  <body>
    <div class="site-canvas">
      <header class="site-header">
        <a class="site-header__brand" href="/">Libretto</a>
        <nav class="site-header__nav" aria-label="Primary">
          <a href="/chapters/03-architecture" aria-current={navCurrent === 'system' ? 'page' : undefined}>System</a>
          <a href="/chapters/04-data-flows" aria-current={navCurrent === 'flows' ? 'page' : undefined}>Flows</a>
          <a href="/chapters/07-agent" aria-current={navCurrent === 'agents' ? 'page' : undefined}>Agents</a>
          <a href="/" aria-current={navCurrent === 'guides' ? 'page' : undefined}>Guides</a>
          <a href={librettoRepo}>Source</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>© {year} Libretto · UBCO COSC499 Group 1</p>
        <p class="site-footer__meta">
          <span>[REV-08]</span>
          <span>STABLE_BUILD</span>
          <a href={capstoneRepo}>CAPSTONE_REPO</a>
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import "../../styles/global.css";
</style>
