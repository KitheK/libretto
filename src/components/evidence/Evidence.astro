---
import { getEvidence } from '../../lib/evidence';

interface Props {
  id: string;
  showPath?: boolean;
}

const { id, showPath = true } = Astro.props;
const entry = getEvidence(id);

function pathFromUrl(url: string): string {
  try {
    const parsed = new URL(url);
    const parts = parsed.pathname.split('/');
    const blobIdx = parts.indexOf('blob');
    if (blobIdx >= 0 && parts.length > blobIdx + 2) {
      return parts.slice(blobIdx + 2).join('/');
    }
    return parsed.pathname;
  } catch {
    return url;
  }
}
---

{!entry ? (
  <aside class="evidence evidence--missing" aria-label="Missing evidence">
    <span class="evidence__label">EVIDENCE</span>
    <span class="evidence__id">{id}</span>
    <span class="evidence__error">Not found in manifest</span>
  </aside>
) : (
  <aside class="evidence" aria-label={`Evidence: ${entry.label}`}>
    <span class="evidence__label">EVIDENCE</span>
    <a
      class="evidence__link"
      href={entry.url}
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="evidence__title">{entry.label}</span>
      {showPath && <span class="evidence__path">{pathFromUrl(entry.url)}</span>}
      <span class="evidence__icon" aria-hidden="true">↗</span>
    </a>
  </aside>
)}
