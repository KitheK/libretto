---
import SiteShell from '../../components/layout/SiteShell.astro';
import DividerRule from '../../components/layout/DividerRule.astro';

const chapterModules = import.meta.glob('../../content/chapters/*.mdx');

const navMap: Record<string, 'system' | 'flows' | 'agents' | 'guides'> = {
  '01-mission': 'guides',
  '02-requirements': 'guides',
  '03-architecture': 'system',
  '04-data-flows': 'flows',
  '05-database': 'system',
  '06-ui': 'guides',
  '07-agent': 'agents',
  '08-canvas-bridge': 'agents',
  '09-dev-process': 'guides',
  '10-history': 'guides',
};

export function getStaticPaths() {
  return [
    { params: { slug: '01-mission' } },
    { params: { slug: '02-requirements' } },
    { params: { slug: '03-architecture' } },
    { params: { slug: '04-data-flows' } },
    { params: { slug: '05-database' } },
    { params: { slug: '06-ui' } },
    { params: { slug: '07-agent' } },
    { params: { slug: '08-canvas-bridge' } },
    { params: { slug: '09-dev-process' } },
    { params: { slug: '10-history' } },
  ];
}

const { slug } = Astro.params;
const modulePath = `../../content/chapters/${slug}.mdx`;
const loader = chapterModules[modulePath];

if (!loader) {
  throw new Error(`Chapter not found: ${slug}`);
}

const { default: Content, frontmatter } = await loader();
const title = frontmatter?.title ?? slug;
const navCurrent = navMap[slug ?? ''] ?? 'guides';
---

<SiteShell title={title} navCurrent={navCurrent}>
  <header class="chapter__mast">
    <p class="chapter__index">{slug}</p>
    <h1 class="chapter__title">{title}</h1>
    {frontmatter?.description && <p class="chapter__desc">{frontmatter.description}</p>}
  </header>

  <DividerRule />

  <article class="prose chapter">
    <Content />
  </article>
</SiteShell>
