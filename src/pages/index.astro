---
import SiteShell from '../components/layout/SiteShell.astro';
import DividerRule from '../components/layout/DividerRule.astro';
import TableOfContents from '../components/layout/TableOfContents.astro';
import Fig001SystemArchitecture from '../components/diagrams/Fig001SystemArchitecture.tsx';
---

<SiteShell title="Libretto" navCurrent="guides">
  <section class="hero">
    <h1 class="hero__wordmark">Conductor</h1>
    <p class="hero__meta">
      A guide to how Group 1 built it.<br />
      <em>— Group 1, UBCO COSC499</em>
    </p>
  </section>

  <DividerRule />

  <TableOfContents />

  <DividerRule />

  <section class="intro-band">
    <div class="intro-band__prose drop-cap">
      <p>
        Have you ever wondered what it takes to let an instructor manage a Canvas course through plain language —
        without giving up control of what actually changes? Conductor is our answer: a microservice stack that routes
        natural-language intent through an agent, previews every mutation, and only then touches the LMS API.
      </p>
      <p>
        Libretto is the manual for that system. Not a README substitute — a reference book in the style of
        <em>Making Software</em>, with diagrams, design rationale, and sources you can verify in the capstone repo.
        Pretty neat.
      </p>
    </div>

    <aside class="diagram-panel" aria-label="System overview diagram">
      <span class="diagram-panel__tag">FIG-001</span>
      <span class="diagram-panel__edge">[ SYSTEM OVERVIEW ]</span>
      <Fig001SystemArchitecture client:visible />
    </aside>
  </section>
</SiteShell>
