---
import SiteShell from '../../components/layout/SiteShell.astro';
import DividerRule from '../../components/layout/DividerRule.astro';
import { getAllEvidence } from '../../lib/evidence';

const entries = getAllEvidence().sort((a, b) => a.id.localeCompare(b.id));
---

<SiteShell title="Evidence index" navCurrent="guides">
  <header class="chapter__mast">
    <p class="chapter__index">APPENDIX</p>
    <h1 class="chapter__title">Evidence manifest</h1>
    <p class="chapter__desc">
      Every Libretto claim maps to a stable ID and a verifiable URL in the capstone repository.
    </p>
  </header>

  <DividerRule />

  <article class="prose">
    <table class="manifest-table">
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Label</th>
          <th scope="col">Source</th>
        </tr>
      </thead>
      <tbody>
        {entries.map((entry) => (
          <tr>
            <td>{entry.id}</td>
            <td>{entry.label}</td>
            <td>
              <a href={entry.url} target="_blank" rel="noopener noreferrer">
                View on GitHub ↗
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </article>
</SiteShell>
